{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": ["node", "express", "cors", "bcryptjs", "jsonwebtoken"]
  },
  "include": ["server.ts", "modules/**/*", "middleware/**/*", "types/**/*", "lib/**/*"],
  "exclude": ["**/*.test.ts", "**/*.spec.ts", "**/tests/**/*", "node_modules"]
}

