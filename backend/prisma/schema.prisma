generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  ADMIN
  PLACEMENT_OFFICER
  RECRUITER
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  name      String   @db.VarChar(255)
  role      UserRole @default(STUDENT)
  tenantId  String?  @map("tenant_id") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("users")
  @@index([email], map: "idx_user_email")
  @@index([tenantId], map: "idx_user_tenant")
}

model Resume {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  title     String   @db.VarChar(255)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  versions  ResumeVersion[]

  @@map("resumes")
  @@index([userId], map: "idx_resume_user")
  @@index([tenantId], map: "idx_resume_tenant")
}

model ResumeVersion {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resumeId      String   @map("resume_id") @db.Uuid
  versionNumber Int      @map("version_number")
  resumeJson    Json     @map("resume_json")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  resume       Resume      @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  atsReports   AtsReport[]

  @@map("resume_versions")
  @@index([resumeId], map: "idx_resume_version")
}

model AtsReport {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resumeId        String   @map("resume_id") @db.Uuid
  versionId       String   @map("version_id") @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  overallScore    Int      @map("overall_score")
  sectionScores   Json     @map("section_scores")
  keywordMatches  Json     @map("keyword_matches")
  issues          Json
  suggestions     Json
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  version         ResumeVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@map("ats_reports")
  @@index([versionId], map: "idx_ats_report_version")
  @@index([resumeId], map: "idx_ats_report_resume")
  @@index([tenantId], map: "idx_ats_report_tenant")
}

model JdMatchReport {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resumeId        String   @map("resume_id") @db.Uuid
  versionId       String   @map("version_id") @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  jobTitle        String?  @map("job_title") @db.VarChar(255)
  jdText          String   @map("jd_text") @db.Text
  overallMatch    Int      @map("overall_match")
  skillsMatch     Json     @map("skills_match")
  keywordMatch    Json     @map("keyword_match")
  experienceMatch Json     @map("experience_match")
  roleFitScore    Int      @map("role_fit_score")
  suggestions     Json
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("jd_match_reports")
  @@index([resumeId], map: "idx_jd_match_resume")
  @@index([versionId], map: "idx_jd_match_version")
  @@index([tenantId], map: "idx_jd_match_tenant")
  @@index([createdAt], map: "idx_jd_match_created")
}

model Job {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String?   @map("tenant_id") @db.Uuid
  title           String    @db.VarChar
  company         String    @db.VarChar
  location        String?   @db.VarChar
  employmentType  String?   @map("employment_type") @db.VarChar
  skillsRequired  Json?     @map("skills_required")
  minExperience   Int?      @map("min_experience")
  maxExperience   Int?      @map("max_experience")
  jdText          String    @map("jd_text") @db.Text
  source          String?   @db.VarChar
  applyLink       String?   @map("apply_link") @db.VarChar
  postedAt        DateTime? @map("posted_at") @db.Timestamp(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("jobs")
  @@index([title], map: "idx_jobs_title")
  @@index([location], map: "idx_jobs_location")
  @@index([tenantId], map: "idx_jobs_tenant")
}
